{# Individual Stat Column #}
<div class="stat-column" style="flex: 1; min-width: 220px; padding: 20px; text-align: center;">
  <div class="stat-number" style="font-size: 2.5rem; font-weight: 800; color: #16a34a; margin-bottom: 8px; line-height: 1;">
    {{ content.field_number[0] }}
  </div>
  <div class="stat-label" style="font-size: 0.95rem; color: #475569; font-weight: 500; line-height: 1.4; max-width: 200px; margin: 0 auto;">
    {{ content.field_label[0] }}
  </div>
</div>
